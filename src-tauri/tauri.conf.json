{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "龙虾管家",
  "version": "0.1.0",
  "identifier": "ai.openclaw.manager",
  "build": {
    "frontendDist": "../packages/web/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev --workspace=@openclaw-manager/web",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "龙虾管家 - OpenClaw Manager",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
